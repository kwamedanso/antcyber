# Frontend Environment Variables Template
# Copy this file to '.env' and fill in the actual values

# ---------------------------------------------------------
# Production / Development API URL
# ---------------------------------------------------------
# This variable connects your frontend to the backend API.
# In local development (if not set), it defaults to your local IP.
# In production, set this to your hosted backend URL (e.g. https://api.yourdomain.com)

# VITE_API_BASE_URL=https://api.yourdomain.com
